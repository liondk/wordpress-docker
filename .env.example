# ==============================
# 🔧 WordPress Docker .env Example
# ==============================

# Domain(s)
DOMAIN=example.com

# Keep latest N database backups and latest N file backups.
KEEP_BACKUPS=7

# ==============================
# 💾 Database Config
# ==============================
MYSQL_DATABASE=wordpress_db
MYSQL_USER=wp_user
MYSQL_PASSWORD=change_me_please
MYSQL_ROOT_PASSWORD=change_root_password

# ==============================
# 🚀 Redis Config
# ==============================
REDIS_HOST=redis
REDIS_PORT=6379

# ==============================
# 📌 VPS Resource Presets
# ==============================
# Only keep one VPS profile uncommented.

# 1GB RAM VPS - default, safe for small sites
MYSQL_INNODB_BUFFER_POOL_SIZE=128M
MYSQL_INNODB_LOG_FILE_SIZE=64M
MYSQL_MAX_CONNECTIONS=30
REDIS_MAXMEMORY=64mb
PHP_MEMORY_LIMIT=256M
PHP_UPLOAD_MAX_FILESIZE=64M
PHP_POST_MAX_SIZE=64M
PHP_MAX_EXECUTION_TIME=300
PHP_MAX_INPUT_VARS=10000
PHP_FPM_MAX_CHILDREN=5
PHP_FPM_START_SERVERS=2
PHP_FPM_MIN_SPARE_SERVERS=1
PHP_FPM_MAX_SPARE_SERVERS=3
PHP_FPM_MAX_REQUESTS=500
#
# 2GB RAM VPS - uncomment this block and comment the 1GB block above
# MYSQL_INNODB_BUFFER_POOL_SIZE=256M
# MYSQL_INNODB_LOG_FILE_SIZE=128M
# MYSQL_MAX_CONNECTIONS=50
# REDIS_MAXMEMORY=128mb
# PHP_MEMORY_LIMIT=256M
# PHP_UPLOAD_MAX_FILESIZE=64M
# PHP_POST_MAX_SIZE=64M
# PHP_MAX_EXECUTION_TIME=300
# PHP_MAX_INPUT_VARS=10000
# PHP_FPM_MAX_CHILDREN=8
# PHP_FPM_START_SERVERS=3
# PHP_FPM_MIN_SPARE_SERVERS=2
# PHP_FPM_MAX_SPARE_SERVERS=5
# PHP_FPM_MAX_REQUESTS=500
#
# 4GB+ RAM VPS - uncomment this block and comment the 1GB block above
# MYSQL_INNODB_BUFFER_POOL_SIZE=512M
# MYSQL_INNODB_LOG_FILE_SIZE=128M
# MYSQL_MAX_CONNECTIONS=80
# REDIS_MAXMEMORY=256mb
# PHP_MEMORY_LIMIT=512M
# PHP_UPLOAD_MAX_FILESIZE=128M
# PHP_POST_MAX_SIZE=128M
# PHP_MAX_EXECUTION_TIME=300
# PHP_MAX_INPUT_VARS=10000
# PHP_FPM_MAX_CHILDREN=15
# PHP_FPM_START_SERVERS=4
# PHP_FPM_MIN_SPARE_SERVERS=2
# PHP_FPM_MAX_SPARE_SERVERS=8
# PHP_FPM_MAX_REQUESTS=500

# ==============================
# 🧱 Optional: Table prefix
# ==============================
WORDPRESS_TABLE_PREFIX=wp_
